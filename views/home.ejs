<% layout("layouts/boilerplate") %>

    <title>Shortify</title>
      <link rel="icon" href="/css/logo.png?v=2" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">

    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
</head>

<body>

<!-- Navbar -->
 
<nav class="navbar navbar-expand-lg navbar-dark shadow custom-navbar">
    <div class="container">
<a href="/" class="navbar-brand d-flex align-items-center">

   <img src="/css/logo.png" class="logo"
         alt="Shortify Logo"
         width="42"
         height="42"
         class="me-2 rounded">

  

</a>



        <a class="navbar-brand fw-bold" href="/">
            <i class="fa-solid fa-link"></i> Shortify
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
            data-bs-target="#navbarNav">

            <span class="navbar-toggler-icon"></span>

        </button>

        <div class="collapse navbar-collapse" id="navbarNav">

            <ul class="navbar-nav ms-auto">

  


                <li class="nav-item">
                    <a class="nav-link active" href="/">Home</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/url/dashboard">Dashboard</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/users/login">Login</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/users/signup">Signup</a>
                </li>

            </ul>

        </div>

    </div>
</nav> 


<!-- Hero -->

<section class="hero">

<div class="container">

<div class="row justify-content-center">

<div class="col-lg-7 col-md-10 col-12">
    
<div class="card shadow-lg border-0 p-5">

<h1 class="text-center fw-bold mb-3">
<i class="fa-solid fa-link"></i>  URL Shortener 
</h1>

<p class="text-center text-muted mb-4">
Create short links instantly and share anywhere.
</p>

<form action="/url/create" method="POST">

<div class="mb-3">

<label class="form-label">
Original URL
</label>

<input
type="url"
name="originalUrl"
class="form-control form-control-lg"
placeholder="https://example.com"
required>

</div>

<div class="mb-4">

<label class="form-label">
Custom Short Code (Optional)
</label>

<input
type="text"
name="customCode"
class="form-control form-control-lg"
placeholder="my-link">

</div>

<button class="btn btn-primary btn-lg w-100">
<i class="fa-solid fa-wand-magic-sparkles"></i>
Create Short URL
</button>

</form>

<hr>
<div class="row text-center">

    <div class="col">
        <div class="feature-card p-3 rounded">
            <h5>⚡ Fast</h5>
            <p class="text-muted mb-0">Generate URLs Instantly</p>
        </div>
    </div>

    <div class="col">
        <div class="feature-card p-3 rounded">
            <h5>🔒 Secure</h5>
            <p class="text-muted mb-0">Safe & Reliable Links</p>
        </div>
    </div>

    <div class="col">
        <div class="feature-card p-3 rounded">
            <h5>🌍 Free</h5>
            <p class="text-muted mb-0">Unlimited URL Shortening</p>
        </div>
    </div>

</div>
</div>

</div>

</div>

</div>

</div>

</section>

<div class="container my-5">

    <h2 class="text-center fw-bold mb-5">
        <i class="fa-solid fa-gears text-primary"></i>
        How It Works
    </h2>

    <div class="row text-center">

        <div class="col-md-3 mb-4">

            <i class="fa-solid fa-link fs-1 text-primary"></i>

            <h5 class="mt-3">Paste URL</h5>

            <p class="text-muted">
                Enter your long URL.
            </p>

        </div>

        <div class="col-md-3 mb-4">

            <i class="fa-solid fa-wand-magic-sparkles fs-1 text-success"></i>

            <h5 class="mt-3">Generate</h5>

            <p class="text-muted">
                Create your short link.
            </p>

        </div>

        <div class="col-md-3 mb-4">

            <i class="fa-solid fa-copy fs-1 text-warning"></i>

            <h5 class="mt-3">Copy</h5>

            <p class="text-muted">
                Copy your new URL.
            </p>

        </div>

        <div class="col-md-3 mb-4">

            <i class="fa-solid fa-share-nodes fs-1 text-danger"></i>

            <h5 class="mt-3">Share</h5>

            <p class="text-muted">
                Share it anywhere.
            </p>

        </div>

    </div>

</div>

<footer class="bg-dark text-white mt-2 py-1">

    <div class="container text-center">

        <h5 class="mb-1">URL Shortener</h5>

        <p class="mb-2">
            Made with  by <strong>Divyansh Singh</strong>
        </p>

        <div class="mb-3">

            <a href="https://github.com/yourusername" target="_blank"
               class="text-white fs-4 me-3">
                <i class="fa-brands fa-github"></i>
            </a>

            <a href="https://www.linkedin.com/in/yourusername" target="_blank"
               class="text-white fs-4 me-3">
                <i class="fa-brands fa-linkedin"></i>
            </a>

            <a href="https://www.instagram.com/divyansh07_31" target="_blank"
               class="text-white fs-4 me-3">
                <i class="fa-brands fa-instagram"></i>
            </a>


        </div>

        <small>
            © 2026 All Rights Reserved
        </small>

    </div>

</footer>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>